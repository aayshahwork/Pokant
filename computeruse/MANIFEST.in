# MANIFEST.in — controls which files are included in source distributions (sdist).
# Binary distributions (wheels) are controlled by package_data in setup.py.

# Documentation
include README.md
include LICENSE
include CHANGELOG.md

# Environment template (never include .env itself)
include .env.example

# Typed package marker
include computeruse/py.typed

# Exclude files that should never appear in a release archive
exclude .env
exclude .env.*
exclude docker-compose*.yml
exclude Dockerfile
exclude .dockerignore
prune .git
prune __pycache__
prune .pytest_cache
prune .mypy_cache
prune sessions
prune replays
prune dist
prune build
