# ===========================================================================
# ComputerUse SDK — Environment Configuration
#
# Copy this file to .env and fill in your values:
#
#     cp .env.example .env
#
# Variables marked "Required" must be set before the SDK will start.
# All others are optional and fall back to the defaults shown here.
# ===========================================================================


# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Anthropic API key used for all model calls.
# Obtain yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...


# ---------------------------------------------------------------------------
# Cloud services
# ---------------------------------------------------------------------------

# BrowserBase API key for managed cloud browser sessions.
# Required when passing local=False to ComputerUse() or use_cloud=True to
# BrowserManager. Leave unset to run browsers locally with Playwright.
BROWSERBASE_API_KEY=your_key_here

# OpenAI API key for optional model fallback.
# Not used by the SDK directly — available for custom executor subclasses.
OPENAI_API_KEY=your_key_here

# AWS credentials for S3 replay and screenshot storage.
# Both AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY must be set together;
# setting only one will trigger a warning at startup and cause S3 uploads
# to fail. Leave both unset to store replays locally only.
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here

# S3 bucket where session replays and screenshots are uploaded.
AWS_BUCKET_NAME=computeruse-replays

# AWS region that hosts the S3 bucket (e.g. us-west-2, eu-central-1).
AWS_REGION=us-east-1


# ---------------------------------------------------------------------------
# Backend services  (cloud API mode only — not required for local SDK usage)
# ---------------------------------------------------------------------------

# asyncpg-compatible PostgreSQL DSN used by the cloud API backend.
DATABASE_URL=postgresql://localhost/computeruse

# Redis connection URL used as the Celery broker and result backend.
REDIS_URL=redis://localhost:6379/0


# ---------------------------------------------------------------------------
# Execution defaults  (override per-task via TaskConfig fields)
# ---------------------------------------------------------------------------

# Anthropic model ID used when none is specified per-task.
# Valid IDs: claude-sonnet-4-5, claude-opus-4-5, claude-haiku-4-5-20251001
DEFAULT_MODEL=claude-sonnet-4-5

# Default wall-clock timeout in seconds for a single task run.
# Override per-task with: cu.run_task(..., timeout_seconds=120)
DEFAULT_TIMEOUT=300

# Default maximum number of browser actions allowed per task run.
# Override per-task with: cu.run_task(..., max_steps=20)
DEFAULT_MAX_STEPS=50


# ---------------------------------------------------------------------------
# Storage directories
# ---------------------------------------------------------------------------

# Directory where browser session state (cookies, localStorage) is persisted
# between runs. Created automatically if it does not exist.
SESSION_DIR=./sessions

# Directory where task replay JSON files and step screenshots are written.
# Created automatically if it does not exist.
REPLAY_DIR=./replays
