# ===========================================================================
# Pokant Production Environment Variables
# ===========================================================================
# Copy this file and fill in real values. Use as a checklist when setting
# Railway env vars.
#
# Scope legend:
#   [BOTH]   — set on BOTH api and worker services
#   [API]    — set on api service only
#   [WORKER] — set on worker service only
# ===========================================================================

# ---------------------------------------------------------------------------
# Environment                                                       [BOTH]
# ---------------------------------------------------------------------------
ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Database (Supabase)                                               [BOTH]
# ---------------------------------------------------------------------------
# Use Session mode pooler (port 5432), NOT Transaction mode (port 6543).
# Transaction mode breaks SET LOCAL used for Row-Level Security.
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Redis (Upstash)                                                   [BOTH]
# ---------------------------------------------------------------------------
# Must use rediss:// (double s) for TLS. Get from Upstash console.
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# ---------------------------------------------------------------------------
# Anthropic                                                         [BOTH]
# ---------------------------------------------------------------------------
# Claude API key for the browser-use agent (worker) and any API-side LLM calls.
ANTHROPIC_API_KEY=sk-ant-api03-XXXXX

# ---------------------------------------------------------------------------
# Browserbase                                                       [BOTH]
# ---------------------------------------------------------------------------
# Cloud browser sessions. Get from browserbase.com dashboard.
BROWSERBASE_API_KEY=bb_live_XXXXX
BROWSERBASE_PROJECT_ID=XXXXX

# ---------------------------------------------------------------------------
# Cloudflare R2 (screenshots & replays)                             [BOTH]
# ---------------------------------------------------------------------------
# S3-compatible object storage. Get from Cloudflare dashboard → R2.
R2_ACCESS_KEY=XXXXX
R2_SECRET_KEY=XXXXX
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=computeruse-recordings

# ---------------------------------------------------------------------------
# Security                                                          [BOTH]
# ---------------------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# MUST be the same on api and worker — used for webhook signing & credential encryption.
API_SECRET_KEY=XXXXX
ENCRYPTION_MASTER_KEY=XXXXX

# ---------------------------------------------------------------------------
# Stripe (billing)                                                  [API]
# ---------------------------------------------------------------------------
# Optional — skip if not using paid tiers yet.
STRIPE_SECRET_KEY=sk_live_XXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXX
# JSON dict mapping tier name to Stripe Price ID
STRIPE_PRICE_IDS={"startup":"price_XXXXX","growth":"price_XXXXX","enterprise":"price_XXXXX"}

# ---------------------------------------------------------------------------
# Dashboard CORS                                                    [API]
# ---------------------------------------------------------------------------
# Set to your Vercel production URL so the API allows cross-origin requests.
DASHBOARD_URL=https://pokant.vercel.app

# ---------------------------------------------------------------------------
# Captcha solving                                                   [WORKER]
# ---------------------------------------------------------------------------
# Optional — only needed if tasks encounter CAPTCHAs.
TWOCAPTCHA_API_KEY=

# ---------------------------------------------------------------------------
# Canary deployment                                                 [WORKER]
# ---------------------------------------------------------------------------
# Set true to enable canary metrics tracking (A/B deployment testing).
CANARY_DEPLOYMENT=false
